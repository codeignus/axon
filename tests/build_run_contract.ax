import
    compiler/proj

test build_contract_depends_on_check
    assert_eq(proj.scope_name_for_command("build"), "project-build")

test run_contract_depends_on_build
    assert_eq(proj.scope_name_for_command("run"), "project-run")

test build_command_uses_no_target
    assert_eq(proj.run_command_name("build"), "build")

test run_command_uses_no_target
    assert_eq(proj.run_command_name("run"), "run")
