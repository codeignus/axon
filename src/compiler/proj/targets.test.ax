test resolve_empty_target_to_project
    assert_eq(resolve_check_target(""), "project")

test resolve_dot_target_to_current_dir
    assert_eq(resolve_check_target("."), "dir:.")

test resolve_recursive_dot_target
    assert_eq(resolve_check_target("./..."), "dir-recursive:./")

test resolve_file_target
    assert_eq(resolve_check_target("src/foo.ax"), "file:src/foo.ax")

test resolve_dir_target
    assert_eq(resolve_check_target("src/compiler"), "dir:src/compiler")

test resolve_recursive_dir_target
    assert_eq(resolve_check_target("src/compiler/..."), "dir-recursive:src/compiler")
