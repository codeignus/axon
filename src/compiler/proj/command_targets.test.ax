import
    compiler/proj/command_targets {
        run_command_name,
        scope_name_for_command,
        fileset_name_for_command,
        resolve_check_target_path,
        resolve_build_target_path,
        resolve_test_target_path,
        target_is_project_scope,
        target_is_file_scope,
        validate_test_file_path,
        resolve_check_targets,
        resolve_test_targets,
        validate_target_in_project
    }

test check_scope_name
	assert_eq(scope_name_for_command("check"), "check")

test test_scope_name
	assert_eq(scope_name_for_command("test"), "test")

test fmt_scope_name
	assert_eq(scope_name_for_command("fmt"), "fmt")

test fmt_matches_check_scope
	assert_eq(fileset_name_for_command("fmt"), fileset_name_for_command("check"))

test validate_src_test_file
	assert_eq(validate_test_file_path("src/compiler/syntax/parser.test.ax"), "ok")

test validate_tests_dir_file
	assert_eq(validate_test_file_path("tests/integration.ax"), "ok")

test reject_non_test_file_in_src
	assert_eq(validate_test_file_path("src/main.ax"), "error: not a valid test target (valid: src/**/*.test.ax, tests/**/*.ax)")

test reject_random_path
	assert_eq(validate_test_file_path("random.ax"), "error: not a valid test target (valid: src/**/*.test.ax, tests/**/*.ax)")

test resolve_check_targets_project_scope
	files := resolve_check_targets("")
	assert_eq(axon_string_starts_with(files, "error:"), false)

test resolve_test_targets_project_scope
	files := resolve_test_targets("")
	assert_eq(axon_string_starts_with(files, "error:"), false)

test validate_project_root_target
	assert_eq(validate_target_in_project("", "."), "ok")

test validate_existing_file_target
	assert_eq(validate_target_in_project("src/main.ax", "."), "ok")

test validate_missing_file_target
	result := validate_target_in_project("src/nope.ax", ".")
	assert_eq(string_contains(result, "error:"), true)
