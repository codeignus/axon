test describe_project_returns_manifest_info
    assert_eq(describe_project(), "project:axon bin:axon main:./src/main.ax")

test list_compiler_modules_returns_layout
    assert_eq(list_compiler_modules(), "compiler/entry,compiler/pipeline_check,compiler/proj/build_file,compiler/proj/module_graph,compiler/proj/discover,compiler/proj/targets,compiler/complex_types/string,compiler/complex_types/array,compiler/ir/ir,compiler/ir/lower,compiler/backend/artifacts,compiler/backend/link,compiler/backend/ffi,compiler/backend/native_codegen,compiler/backend/foreign_archive,compiler/bootstrap/protocol,compiler/bootstrap/rust_bridge")

test discover_entry_returns_main_path
    assert_eq(discover_entry(), "./src/main.ax")

test discover_classify_has_sidecar
    result := classify_file_pair("src/compiler/proj/discover.ax")
    assert_eq(result, "has-sidecar")

test discover_classify_pure_axon
    result := classify_file_pair("src/compiler/proj/build_file.ax")
    assert_eq(result, "pure-axon")

test discover_import_path_to_file_direct
    result := import_path_to_file_path("compiler/proj/build_file")
    assert_eq(result, "src/compiler/proj/build_file.ax")

test discover_import_path_to_dir_module
    result := import_path_to_file_path("compiler/proj")
    assert_eq(string_contains(result, "src/compiler/proj"), true)

test discover_import_path_not_found
    result := import_path_to_file_path("nonexistent/module")
    assert_eq(result, "not-found")

test resolve_check_target_returns_project_scope
    assert_eq(resolve_check_target(""), "project")

test resolve_test_target_returns_project_scope
    assert_eq(resolve_test_target(""), "test:project")
