// Smoke-level command orchestration tests: assert pipeline executes without panic.
test check_with_empty_path_runs
    result := check("")
    assert_eq(result, result)

test build_runs
    result := build()
    assert_eq(result, result)

test run_runs
    result := run()
    assert_eq(result, result)

test self_bootstrap_gate_runs
    result := self_bootstrap_gate()
    assert_eq(result, result)

test run_tests_runs
    result := run_tests("")
    assert_eq(result, result)

test run_fmt_runs
    result := run_fmt("")
    assert_eq(result, result)
