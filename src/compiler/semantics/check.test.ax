// Fixture parity tests for semantic duplicate-name diagnostics.
test semantic_snippet_rejects_duplicate_function
    source := "func hello() String\n    return \"a\"\n\nfunc hello() String\n    return \"b\"\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "yes")

test semantic_snippet_accepts_distinct_functions
    source := "func hello() String\n    return \"a\"\n\nfunc world() String\n    return \"b\"\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "no")

test semantic_snippet_rejects_unresolved_call
    source := "func hello() String\n    unknown_fn()\n    return \"a\"\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "yes")

test semantic_snippet_rejects_arity_mismatch
    source := "func add(a: Int, b: Int) Int\n    return 1\n\nfunc main() Int\n    add(1)\n    return 0\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "yes")

test semantic_snippet_accepts_len_method_with_complex_type_helpers
    source := "func string_len(s: String) Int\n    return 1\n\nfunc main() Int\n    \"hi\".len()\n    return 0\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "no")

test semantic_snippet_rejects_len_on_int_receiver
    source := "func main() Int\n    42.len()\n    return 0\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "yes")

test semantic_snippet_rejects_arg_type_mismatch
    source := "func takes_int(v: Int) Int\n    return v\n\nfunc main() Int\n    takes_int(\"bad\")\n    return 0\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "yes")

test semantic_snippet_accepts_int_literal_for_Int_param
    source := "func takes_int(v: Int) Int\n    return v\n\nfunc main() Int\n    takes_int(42)\n    return 0\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "no")

test semantic_snippet_accepts_i32_literal_for_i64_param
    source := "func f(v: i64) i64\n    return v\n\nfunc main() i64\n    f(1)\n    return 0\n"
    got := run_semantic_check_for_source(source)
    assert_eq(message_is_error(got), "no")

test resolve_detects_duplicate_braced_imports
    source := "import\n    compiler/a { foo }\n    compiler/b { foo }\n\nfunc main() void\n    return\n"
    got := check_duplicate_braced_imports(source)
    assert_eq(string_contains(got, "duplicate import"), true)

test resolve_accepts_distinct_braced_imports
    source := "import\n    compiler/a { foo }\n    compiler/b { bar }\n\nfunc main() void\n    return\n"
    got := check_duplicate_braced_imports(source)
    assert_eq(got, "")

test resolve_accepts_empty_source
    source := ""
    got := check_duplicate_braced_imports(source)
    assert_eq(got, "")

// --- Phase 4: duplicate declaration tests ---

test duplicate_func_declaration_detected
    source := "func hello() String\n    return \"a\"\n\nfunc hello() String\n    return \"b\"\n"
    got := check_duplicate_declarations_axon(source)
    assert_eq(string_contains(got, "duplicate func"), true)

test duplicate_struct_declaration_detected
    source := "struct Foo\n    x: i64\n\nstruct Foo\n    y: i64\n"
    got := check_duplicate_declarations_axon(source)
    assert_eq(string_contains(got, "duplicate struct"), true)

test duplicate_enum_declaration_detected
    source := "enum Color\n    Red\n    Green\n\nenum Color\n    Blue\n"
    got := check_duplicate_declarations_axon(source)
    assert_eq(string_contains(got, "duplicate enum"), true)

test duplicate_trait_declaration_detected
    source := "trait Printable\n    fmt() String\n\ntrait Printable\n    show() String\n"
    got := check_duplicate_declarations_axon(source)
    assert_eq(string_contains(got, "duplicate trait"), true)

test distinct_declarations_pass
    source := "func hello() String\n    return \"a\"\n\nstruct Point\n    x: i64\n\nenum Color\n    Red\n"
    got := check_duplicate_declarations_axon(source)
    assert_eq(got, "")

// --- Phase 4: self-import tests ---

test self_import_rejected
    source := "import\n    compiler/semantics { check_imports }\n\nfunc main() void\n    return\n"
    got := check_self_import_axon(source, "compiler/semantics")
    assert_eq(string_contains(got, "self-import"), true)

test non_self_import_accepted
    source := "import\n    compiler/semantics { check_imports }\n\nfunc main() void\n    return\n"
    got := check_self_import_axon(source, "compiler/diagnostics")
    assert_eq(got, "")

// --- Phase 4: import collision tests ---

test import_collision_with_local_func_detected
    source := "import\n    compiler/types/composites/string { string_len }\n\nfunc string_len(s: String) i64\n    return 0\n"
    got := check_import_collision_axon(source)
    assert_eq(string_contains(got, "collides with local declaration"), true)

test no_collision_with_distinct_names
    source := "import\n    compiler/types/composites/string { string_len }\n\nfunc my_func() String\n    return \"ok\"\n"
    got := check_import_collision_axon(source)
    assert_eq(got, "")

// --- Phase 4: visibility tests ---

test visibility_violation_detected
    source := "func helper() String\n    return \"inner\"\n\nfunc main() String\n    return helper()\n"
    got := check_visibility_axon(source)
    // helper is private but called from main — within same module this is ok
    // visibility only flags cross-module issues; same-source calls are fine
    assert_eq(got, "")

test pub_func_visibility_ok
    source := "pub func exported() String\n    return \"ok\"\n\nfunc main() String\n    return exported()\n"
    got := check_visibility_axon(source)
    assert_eq(got, "")

// --- Phase 4: build_symbol_table tests ---

test build_symbol_table_finds_func
    source := "func hello() String\n    return \"a\"\n\npub func world() String\n    return \"b\"\n"
    got := build_symbol_table_axon(source)
    assert_eq(string_contains(got, "hello:func:0"), true)
    assert_eq(string_contains(got, "world:func:1"), true)

test build_symbol_table_finds_struct_and_enum
    source := "struct Point\n    x: i64\n\npub enum Color\n    Red\n"
    got := build_symbol_table_axon(source)
    assert_eq(string_contains(got, "Point:struct:0"), true)
    assert_eq(string_contains(got, "Color:enum:1"), true)

// --- Phase 4: resolve_all_imports tests ---

test resolve_all_imports_empty_source
    got := resolve_all_imports_axon("")
    assert_eq(got, "ok:resolve:empty")

test resolve_all_imports_valid_source
    source := "import\n    compiler/types/composites/string { string_len }\n\nfunc main() String\n    return \"ok\"\n"
    got := resolve_all_imports_axon(source)
    assert_eq(string_contains(got, "ok:resolve"), true)

// --- Phase 4: full semantic check chaining ---

test full_semantic_check_valid_source
    source := "func hello() String\n    return \"a\"\n\nfunc main() String\n    return hello()\n"
    got := run_full_semantic_check(source)
    assert_eq(got, "ok:full-semantic")

test full_semantic_check_catches_duplicate
    source := "func hello() String\n    return \"a\"\n\nfunc hello() String\n    return \"b\"\n"
    got := run_full_semantic_check(source)
    assert_eq(string_contains(got, "duplicate"), true)

test full_semantic_check_catches_unresolved
    source := "func main() String\n    return unknown()\n"
    got := run_full_semantic_check(source)
    assert_eq(message_is_error(got), "yes")

test full_semantic_check_empty_source
    got := run_full_semantic_check("")
    assert_eq(got, "ok:full-semantic:empty")

test full_semantic_check_catches_unreachable_after_return
    source := "func main() void\n    return\n    print(\"x\")\n"
    got := run_full_semantic_check(source)
    assert_eq(message_is_error(got), "yes")
    assert_eq(string_contains(got, "lint"), true)

// --- Phase 4 remaining: struct member duplicate tests ---

test struct_duplicate_field_detected
    source := "struct Point\n    x: i64\n    y: i64\n    x: String\n"
    got := check_struct_member_duplicates(source)
    assert_eq(string_contains(got, "duplicate struct field"), true)

test struct_distinct_fields_pass
    source := "struct Point\n    x: i64\n    y: i64\n    z: i64\n"
    got := check_struct_member_duplicates(source)
    assert_eq(got, "")

test struct_empty_body_pass
    source := "struct Empty\n"
    got := check_struct_member_duplicates(source)
    assert_eq(got, "")

test struct_pub_decl_duplicate_detected
    source := "pub struct Config\n    name: String\n    name: String\n"
    got := check_struct_member_duplicates(source)
    assert_eq(string_contains(got, "duplicate struct field"), true)

test struct_multiple_structs_each_checked
    source := "struct A\n    x: i64\n    y: i64\n\nstruct B\n    a: String\n    b: String\n"
    got := check_struct_member_duplicates(source)
    assert_eq(got, "")

// --- Phase 4 remaining: enum variant duplicate tests ---

test enum_duplicate_variant_detected
    source := "enum Color\n    Red\n    Green\n    Red\n"
    got := check_enum_variant_duplicates(source)
    assert_eq(string_contains(got, "duplicate enum variant"), true)

test enum_distinct_variants_pass
    source := "enum Color\n    Red\n    Green\n    Blue\n"
    got := check_enum_variant_duplicates(source)
    assert_eq(got, "")

test enum_empty_body_pass
    source := "enum Empty\n"
    got := check_enum_variant_duplicates(source)
    assert_eq(got, "")

test enum_pub_decl_duplicate_detected
    source := "pub enum Status\n    Ok\n    Err\n    Ok\n"
    got := check_enum_variant_duplicates(source)
    assert_eq(string_contains(got, "duplicate enum variant"), true)

test enum_variants_with_args_checked
    source := "enum Expr\n    Num(i64)\n    Add(Expr, Expr)\n    Num(String)\n"
    got := check_enum_variant_duplicates(source)
    assert_eq(string_contains(got, "duplicate enum variant"), true)

// --- Phase 4 remaining: trait method duplicate tests ---

test trait_duplicate_method_detected
    source := "trait Printable\n    fmt() String\n    show() String\n    fmt() String\n"
    got := check_trait_method_duplicates(source)
    assert_eq(string_contains(got, "duplicate trait method"), true)

test trait_distinct_methods_pass
    source := "trait Drawable\n    draw() void\n    resize(factor: i64) void\n"
    got := check_trait_method_duplicates(source)
    assert_eq(got, "")

test trait_empty_body_pass
    source := "trait Empty\n"
    got := check_trait_method_duplicates(source)
    assert_eq(got, "")

test trait_pub_decl_duplicate_detected
    source := "pub trait Comparable\n    compare(other: Self) i64\n    compare(other: Self) bool\n"
    got := check_trait_method_duplicates(source)
    assert_eq(string_contains(got, "duplicate trait method"), true)

// --- Phase 4 remaining: method self-rule tests ---

test impl_method_with_self_passes
    source := "struct Point\n    x: i64\n\nimpl Point\n    get_x(self) i64\n        return self.x\n"
    got := check_method_self_rules(source)
    assert_eq(got, "")

test impl_method_missing_self_flagged
    source := "struct Point\n    x: i64\n\nimpl Point\n    get_x() i64\n        return 0\n"
    got := check_method_self_rules(source)
    assert_eq(string_contains(got, "must have 'self' as first parameter"), true)

test impl_method_no_params_allowed
    source := "struct Point\n    x: i64\n\nimpl Point\n    new() Point\n        return Point{x: 0}\n"
    got := check_method_self_rules(source)
    assert_eq(got, "")

test impl_multiple_methods_all_valid
    source := "struct Pair\n    a: i64\n    b: i64\n\nimpl Pair\n    first(self) i64\n        return self.a\n    second(self) i64\n        return self.b\n"
    got := check_method_self_rules(source)
    assert_eq(got, "")

test impl_multiple_methods_one_bad
    source := "struct Pair\n    a: i64\n\nimpl Pair\n    first(self) i64\n        return self.a\n    broken() i64\n        return 0\n"
    got := check_method_self_rules(source)
    assert_eq(string_contains(got, "must have 'self' as first parameter"), true)

test method_self_rules_empty_source
    got := check_method_self_rules("")
    assert_eq(got, "")

// --- Phase 4 remaining: import alias conflict tests ---

test import_alias_conflict_detected
    source := "import\n    compiler/a as foo\n    compiler/b as foo\n\nfunc main() void\n    return\n"
    got := check_import_alias_conflicts(source)
    assert_eq(string_contains(got, "duplicate import alias"), true)

test import_distinct_aliases_pass
    source := "import\n    compiler/a as fa\n    compiler/b as fb\n\nfunc main() void\n    return\n"
    got := check_import_alias_conflicts(source)
    assert_eq(got, "")

test import_no_aliases_pass
    source := "import\n    compiler/types/composites/string { string_len }\n\nfunc main() void\n    return\n"
    got := check_import_alias_conflicts(source)
    assert_eq(got, "")

test import_alias_conflicts_empty_source
    got := check_import_alias_conflicts("")
    assert_eq(got, "")

// --- Phase 4 remaining: resolve_aliased_imports tests ---

test resolve_aliased_imports_finds_aliases
    source := "import\n    compiler/a as fa\n    compiler/b as fb\n\nfunc main() void\n    return\n"
    got := resolve_aliased_imports(source)
    assert_eq(string_contains(got, "fa=compiler/a"), true)
    assert_eq(string_contains(got, "fb=compiler/b"), true)

test resolve_aliased_imports_empty_when_no_aliases
    source := "import\n    compiler/types/composites/string { string_len }\n\nfunc main() void\n    return\n"
    got := resolve_aliased_imports(source)
    assert_eq(got, "")

test resolve_aliased_imports_empty_source
    got := resolve_aliased_imports("")
    assert_eq(got, "")
