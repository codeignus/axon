pub func report_error(msg: String) void
    print(msg)

pub func error_with_code(msg: String) void
    print(msg)

pub func fail_not_implemented(area: String) String
    return axon_fail(area)

pub func compiler_error(kind: String, msg: String) String
    return diag_error(kind, msg)

pub func internal_compiler_error(msg: String) String
    return diag_internal(msg)
