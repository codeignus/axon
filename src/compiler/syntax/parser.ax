// Native parser helpers (incremental port). Keep sidecar checks for now.
pub func parse_balance_native(source: String) String
    opens := axon_string_count(source, "(") + axon_string_count(source, "[") + axon_string_count(source, "{")
    closes := axon_string_count(source, ")") + axon_string_count(source, "]") + axon_string_count(source, "}")
    if opens == closes:
        return "ok"
    return "error: parser: unbalanced delimiters"
