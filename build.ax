project axon
    version: "0.1.0"

bin axon
    main: "./src/main.ax"

rust_deps
    tracing = "0.1"
    tracing-subscriber = { version = "0.3", features = ["fmt", "env-filter"] }
    clap = { version = "4", features = ["derive"] }
    inkwell = { version = "0.8.0", features = ["llvm21-1"] }
    serde = { version = "1", features = ["derive"] }
    serde_json = "1"
